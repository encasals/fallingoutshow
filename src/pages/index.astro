<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:title" content="Falling Out Show" />
    <meta property="og:image" content="https://cdn.myportfolio.com/4f22ae2f-f331-4f4a-b152-c2dc84df9f9b/80c7ed14-eb94-4df5-a6e2-d26b9704a564_rwc_0x0x6000x3376x6000.jpg?h=8b52c1a0f678db866be4bf3566440838" />
    <link rel="icon" href="https://cdn.myportfolio.com/4f22ae2f-f331-4f4a-b152-c2dc84df9f9b/4331ec72-ccc1-4088-b944-5c3076d44f7b_carw_1x1x32.png?h=ce682483bf59d9fc96f2a12c35a6344d" />
    <link rel="apple-touch-icon" href="https://cdn.myportfolio.com/4f22ae2f-f331-4f4a-b152-c2dc84df9f9b/e2821117-4bda-4a85-9657-e1adbfc74099_carw_1x1x180.png?h=636efb21f75f30254284de6de8fc73f5" />
    <title>Falling Out Show</title>
  </head>
  <body>
    <main class="container">
      <!-- Logo -->
      <section class="logo-section">
        <img 
          src="https://cdn.myportfolio.com/4f22ae2f-f331-4f4a-b152-c2dc84df9f9b/cb25ca9c-f8b3-4f9c-bc06-0fba53c666f9_rw_1920.png?h=2c53169db4b1045e9384710b5ec4e6ef" 
          alt="Falling Out Show Logo"
          class="logo"
        />
      </section>

      <!-- Trailer Section -->
      <section class="section">
        <h2 class="section-title">TRAILER</h2>
        <div class="video-container">
          <iframe 
            src="https://www.youtube.com/embed/i4CHVmHzMjY?si=wYI_P6ONO1NL-g5g" 
            frameborder="0" 
            allow="autoplay; picture-in-picture" 
            allowfullscreen
            title="Falling Out Show Trailer"
          ></iframe>
        </div>
      </section>

      <!-- Episodes Section -->
      <section class="section">
        <h2 class="section-title">EPISODES</h2>
        {episodes.map((episode, index) => (
          <div class="episode">
            <div class="video-container">
              <iframe 
                src={`https://www.youtube.com/embed/${episode.youtubeId}`}
                frameborder="0" 
                allow="autoplay; picture-in-picture" 
                allowfullscreen
                title={episode.title}
              ></iframe>
            </div>
            <p class="episode-link">
              {episode.title.toUpperCase()} LINK: <a href={episode.link}>{episode.link}</a>
            </p>
          </div>
        ))}
      </section>

      <!-- Credits Section -->
      <section class="section credits-section">
        <h2 class="section-title">CREDITS</h2>
        <div class="credits-list">
          {credits.map((credit) => (
            <p class="credit-item">{credit.name} - {credit.role}</p>
          ))}
          <p class="credit-item additional-voices">ADDITIONAL VOICES - ADAM NIELD & JOSH HERRING</p>
        </div>
      </section>

      <!-- Gallery Section -->
      <section class="section gallery-section">
        <div class="gallery">
          {galleryImages.map((image, index) => (
            <div class={`gallery-item ${image.portrait ? 'portrait' : 'landscape'}`}>
              <img 
                src={image.src} 
                alt={`Behind the scenes photo ${index + 1}`}
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <p>all rights reserved &copy; 2023</p>
      <p>Alex Baro-Cayetano</p>
    </footer>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: Helvetica, Arial, sans-serif;
    background-color: #f5a9a9;
    color: #000;
    line-height: 1.4;
  }

  .container {
    max-width: 700px;
    margin: 0 auto;
    padding: 30px 20px;
  }

  .logo-section {
    text-align: center;
    margin-bottom: 10px;
  }

  .logo {
    max-width: 100%;
    height: auto;
  }

  .section {
    margin-bottom: 20px;
    text-align: center;
  }

  .section-title {
    font-size: 12px;
    font-weight: bold;
    margin-bottom: 10px;
    color: #000;
    text-align: center;
    letter-spacing: 0.5px;
  }

  .video-container {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin: 0 auto 10px;
    aspect-ratio: 16 / 9;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .episode {
    margin-bottom: 20px;
  }

  .episode-link {
    text-align: center;
    font-size: 11px;
    margin-top: 5px;
  }

  .episode-link a {
    color: #000;
    text-decoration: none;
  }

  .episode-link a:hover {
    text-decoration: underline;
  }

  .credits-section {
    text-align: center;
    margin-top: 10px;
  }

  .credits-list {
    line-height: 1.6;
  }

  .credit-item {
    font-size: 10px;
    line-height: 1.6;
  }

  .additional-voices {
    margin-top: 12px;
  }

  .gallery-section {
    margin-top: 30px;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    max-width: 100%;
  }

  .gallery-item {
    overflow: hidden;
    background-color: #e8a0a0;
    aspect-ratio: 1;
  }

  .gallery-item.landscape {
    grid-column: span 1;
  }

  .gallery-item.portrait {
    grid-column: span 1;
  }

  /* First row - 5 items */
  .gallery-item:nth-child(1) { grid-column: span 1; }
  .gallery-item:nth-child(2) { grid-column: span 1; }
  .gallery-item:nth-child(3) { grid-column: span 1; }
  .gallery-item:nth-child(4) { grid-column: span 1; }
  .gallery-item:nth-child(5) { grid-column: span 1; }
  
  /* Second row - 5 items */
  .gallery-item:nth-child(6) { grid-column: span 1; }
  .gallery-item:nth-child(7) { grid-column: span 1; }
  .gallery-item:nth-child(8) { grid-column: span 1; }
  .gallery-item:nth-child(9) { grid-column: span 1; }
  .gallery-item:nth-child(10) { grid-column: span 1; }
  
  /* Third row - portraits spanning 2 rows, landscapes filling */
  .gallery-item:nth-child(11) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }
  .gallery-item:nth-child(12) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }
  .gallery-item:nth-child(13) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }
  .gallery-item:nth-child(14) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }
  .gallery-item:nth-child(15) { grid-column: span 2; aspect-ratio: 16/9; }
  .gallery-item:nth-child(16) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.02);
  }

  .footer {
    text-align: center;
    padding: 30px 20px;
    font-size: 11px;
    color: #000;
  }

  .footer p {
    margin: 4px 0;
  }

  @media (max-width: 768px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
    }
    
    .gallery-item,
    .gallery-item:nth-child(n) {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
      aspect-ratio: 1 !important;
    }
  }

  @media (max-width: 480px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }

    .container {
      padding: 20px 15px;
    }
  }
</style>
