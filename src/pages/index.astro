---
// Falling Out Show - Main Page
import { Image, getImage } from 'astro:assets';

// Import local images for optimization
import logoImage from '../assets/images/logo.png';
import gallery1 from '../assets/images/gallery/gallery-1.jpg';
import gallery2 from '../assets/images/gallery/gallery-2.jpg';
import gallery3 from '../assets/images/gallery/gallery-3.jpg';
import gallery4 from '../assets/images/gallery/gallery-4.jpg';
import gallery5 from '../assets/images/gallery/gallery-5.jpg';
import gallery6 from '../assets/images/gallery/gallery-6.jpg';
import gallery7 from '../assets/images/gallery/gallery-7.jpg';
import gallery8 from '../assets/images/gallery/gallery-8.jpg';
import gallery9 from '../assets/images/gallery/gallery-9.jpg';
import gallery10 from '../assets/images/gallery/gallery-10.jpg';
import gallery11 from '../assets/images/gallery/gallery-11.jpg';
import gallery12 from '../assets/images/gallery/gallery-12.jpg';
import gallery13 from '../assets/images/gallery/gallery-13.jpg';
import gallery14 from '../assets/images/gallery/gallery-14.jpg';
import gallery15 from '../assets/images/gallery/gallery-15.jpg';
import gallery16 from '../assets/images/gallery/gallery-16.jpg';

const episodes = [
  {
    title: "Episode 1",
    youtubeId: "OgCbB0rcAkE",
    link: "https://youtu.be/8wXft4uNmPA"
  },
  {
    title: "Episode 2", 
    youtubeId: "YKNYiLREjfs",
    link: "https://youtu.be/pFmzMylBUT4"
  },
  {
    title: "Episode 3",
    youtubeId: "u-xVdSYCHX4",
    link: "https://youtu.be/Gi1WHeSQ388"
  }
];

const credits = [
  { role: "Writer and Director", name: "Alex Baro-Cayetano" },
  { role: "Fatima", name: "Susu Ahmed" },
  { role: "Emal", name: "Emal Saifi" },
  { role: "Zero", name: "Bear Winter-Perreau" },
  { role: "Mike", name: "Kimani Campbell" },
  { role: "Jamie", name: "Ekow Otoo" },
  { role: "Sophie", name: "Helen Thomas" },
  { role: "Henry", name: "Yinka Olabode" },
  { role: "Stormzy", name: "Jamie Bozonga" },
  { role: "Neighbour Steve", name: "Brock Hutton" },
  { role: "Dead woman", name: "Philippine Bouchez" },
  { role: "Croydon survivor", name: "Josh Herring" },
  { role: "Stunts", name: "Axel Nu" },
  { role: "Stunts", name: "Michael Worwood" },
  { role: "Stunt Department Manager", name: "Jean-Paul Ly" },
  { role: "DOP", name: "Anand Singh" },
  { role: "2nd Cam Op / Gaffer", name: "Jay Whylie" },
  { role: "First AD", name: "Greg Furber" },
  { role: "Second AD", name: "Daniel Oluwasayo Olabode" },
  { role: "Sound Recordist", name: "Rufus Ambler" },
  { role: "Costume Design", name: "Elisa Ghysels" },
  { role: "Prosthetics", name: "Chelsea Murphy" },
  { role: "Catering", name: "Hannah Robinson" },
  { role: "Runner", name: "George Jamieson" },
  { role: "VFX Compositor", name: "Eddy Idris" },
  { role: "VFX Compositor", name: "Chris Fryer" },
  { role: "VFX Compositor", name: "Alexandre Prod'homme" },
  { role: "Roto Artist", name: "Nazmul Hossain Nahid" },
  { role: "Grade", name: "Anand Singh" },
  { role: "Sound Supervisor", name: "Nicola Itro" },
  { role: "Script Editor", name: "James Saunders" },
  { role: "Script Editor", name: "Peter Fellows" },
  { role: "Script Editor", name: "Dan McGrath" },
  { role: "Executive Producer", name: "Alex Baro-Cayetano" },
  { role: "Executive Producer", name: "Peter Fellows" },
];

const galleryImages = [
  { src: gallery1, portrait: true },
  { src: gallery2, portrait: false },
  { src: gallery3, portrait: false },
  { src: gallery4, portrait: false },
  { src: gallery5, portrait: false },
  { src: gallery6, portrait: false },
  { src: gallery7, portrait: false },
  { src: gallery8, portrait: false },
  { src: gallery9, portrait: false },
  { src: gallery10, portrait: false },
  { src: gallery11, portrait: true },
  { src: gallery12, portrait: true },
  { src: gallery13, portrait: true },
  { src: gallery14, portrait: true },
  { src: gallery15, portrait: false },
  { src: gallery16, portrait: true },
];

// Generate large optimized images for lightbox
const largeImages = await Promise.all(
  galleryImages.map(async (img) => {
    const optimized = await getImage({
      src: img.src,
      width: 1200,
      format: 'webp',
      quality: 85,
    });
    return optimized.src;
  })
);
---

<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- Primary Meta Tags -->
    <title>Falling Out | Apocalypse Comedy Zombie Series by Alex Baro-Cayetano</title>
    <meta name="title" content="Falling Out | Apocalypse Comedy Zombie Series by Alex Baro-Cayetano" />
    <meta name="description" content="Watch Falling Out, a British apocalypse comedy zombie web series created by Alex Baro-Cayetano. Stream all 3 episodes free. Featuring Susu Ahmed, Emal Saifi, Bear Winter-Perreau and more." />
    <meta name="keywords" content="Falling Out, zombie series, apocalypse comedy, British web series, Alex Baro-Cayetano, zombie comedy, indie film, web series 2023" />
    <meta name="author" content="Alex Baro-Cayetano" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.fallingoutshow.com/" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="video.tv_show" />
    <meta property="og:url" content="https://www.fallingoutshow.com/" />
    <meta property="og:title" content="Falling Out | Apocalypse Comedy Zombie Series" />
    <meta property="og:description" content="Watch Falling Out, a British apocalypse comedy zombie web series. Stream all 3 episodes free. Created by Alex Baro-Cayetano." />
    <meta property="og:image" content="https://www.fallingoutshow.com/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Falling Out Show" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://www.fallingoutshow.com/" />
    <meta name="twitter:title" content="Falling Out | Apocalypse Comedy Zombie Series" />
    <meta name="twitter:description" content="Watch Falling Out, a British apocalypse comedy zombie web series. Stream all 3 episodes free. Created by Alex Baro-Cayetano." />
    <meta name="twitter:image" content="https://www.fallingoutshow.com/og-image.jpg" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    
    <!-- Schema.org JSON-LD structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "TVSeries",
      "name": "Falling Out",
      "description": "A British apocalypse comedy zombie web series following survivors navigating the end of the world with dark humor.",
      "genre": ["Comedy", "Horror", "Zombie"],
      "numberOfEpisodes": 3,
      "datePublished": "2023",
      "creator": {
        "@type": "Person",
        "name": "Alex Baro-Cayetano"
      },
      "director": {
        "@type": "Person",
        "name": "Alex Baro-Cayetano"
      },
      "actor": [
        { "@type": "Person", "name": "Susu Ahmed" },
        { "@type": "Person", "name": "Emal Saifi" },
        { "@type": "Person", "name": "Bear Winter-Perreau" },
        { "@type": "Person", "name": "Kimani Campbell" },
        { "@type": "Person", "name": "Ekow Otoo" },
        { "@type": "Person", "name": "Helen Thomas" },
        { "@type": "Person", "name": "Yinka Olabode" }
      ],
      "image": "https://www.fallingoutshow.com/og-image.jpg",
      "url": "https://www.fallingoutshow.com/",
      "countryOfOrigin": {
        "@type": "Country",
        "name": "United Kingdom"
      }
    }
    </script>
  </head>
  <body>
    <main class="container">
      <!-- Logo -->
      <section class="logo-section">
        <Image 
          src={logoImage}
          alt="Falling Out Show Logo"
          class="logo"
          width={800}
          format="webp"
          quality={80}
          loading="eager"
        />
      </section>

      <!-- Trailer Section -->
      <section class="section">
        <h2 class="section-title">TRAILER</h2>
        <div class="video-container">
          <iframe 
            src="https://www.youtube.com/embed/i4CHVmHzMjY?si=wYI_P6ONO1NL-g5g" 
            frameborder="0" 
            allow="autoplay; picture-in-picture" 
            allowfullscreen
            title="Falling Out Show Trailer"
          ></iframe>
        </div>
      </section>

      <!-- Episodes Section -->
      <section class="section">
        <h2 class="section-title">EPISODES</h2>
        {episodes.map((episode, index) => (
          <div class="episode">
            <div class="video-container">
              <iframe 
                src={`https://www.youtube.com/embed/${episode.youtubeId}`}
                frameborder="0" 
                allow="autoplay; picture-in-picture" 
                allowfullscreen
                title={episode.title}
              ></iframe>
            </div>
            <p class="episode-link">
              {episode.title.toUpperCase()} LINK: <a href={episode.link}>{episode.link}</a>
            </p>
          </div>
        ))}
      </section>

      <!-- Credits Section -->
      <section class="section credits-section">
        <h2 class="section-title">CREDITS</h2>
        <div class="credits-list">
          {credits.map((credit) => (
            <p class="credit-item">{credit.name} - {credit.role}</p>
          ))}
          <p class="credit-item additional-voices">ADDITIONAL VOICES - ADAM NIELD & JOSH HERRING</p>
        </div>
      </section>

      <!-- Gallery Section -->
      <section class="section gallery-section">
        <div class="gallery">
          {galleryImages.map((image, index) => (
            <div 
              class={`gallery-item ${image.portrait ? 'portrait' : 'landscape'}`}
              data-index={index}
              data-large-src={largeImages[index]}
              role="button"
              tabindex="0"
              aria-label={`View behind the scenes photo ${index + 1}`}
            >
              <Image 
                src={image.src} 
                alt={`Behind the scenes photo ${index + 1}`}
                width={image.portrait ? 300 : 400}
                format="webp"
                quality={75}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      </section>
    </main>

    <!-- Image Preview Lightbox -->
    <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Image preview">
      <button class="lightbox-close" id="lightbox-close" aria-label="Close preview">&times;</button>
      <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Previous image">&#10094;</button>
      <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Next image">&#10095;</button>
      <div class="lightbox-content">
        <img id="lightbox-img" src="" alt="" />
        <div class="lightbox-counter" id="lightbox-counter"></div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
      <p>all rights reserved &copy; 2023</p>
      <p>Alex Baro-Cayetano</p>
    </footer>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: Helvetica, Arial, sans-serif;
    background-color: #f5a9a9;
    color: #000;
    line-height: 1.4;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 30px 20px;
  }

  .logo-section {
    text-align: center;
    margin-bottom: 10px;
  }

  .logo {
    max-width: 100%;
    height: auto;
  }

  .section {
    margin-bottom: 20px;
    text-align: center;
  }

  .section-title {
    font-size: 12px;
    font-weight: bold;
    margin-bottom: 10px;
    color: #000;
    text-align: center;
    letter-spacing: 0.5px;
  }

  .video-container {
    position: relative;
    width: 100%;
    max-width: 640px;
    margin: 0 auto 10px;
    aspect-ratio: 16 / 9;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .episode {
    margin-bottom: 20px;
  }

  .episode-link {
    text-align: center;
    font-size: 12px;
    margin-top: 5px;
  }

  .episode-link a {
    color: #000;
    text-decoration: none;
  }

  .episode-link a:hover {
    text-decoration: underline;
  }

  .credits-section {
    text-align: center;
    margin-top: 10px;
  }

  .credits-list {
    line-height: 1.6;
  }

  .credit-item {
    font-size: 11px;
    line-height: 1.6;
  }

  .additional-voices {
    margin-top: 12px;
  }

  .gallery-section {
    margin-top: 30px;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    max-width: 100%;
  }

  .gallery-item {
    overflow: hidden;
    background-color: #e8a0a0;
    aspect-ratio: 1;
  }

  .gallery-item.landscape {
    grid-column: span 1;
  }

  .gallery-item.portrait {
    grid-column: span 1;
  }

  /* First row - 5 items */
  .gallery-item:nth-child(1) { grid-column: span 1; }
  .gallery-item:nth-child(2) { grid-column: span 1; }
  .gallery-item:nth-child(3) { grid-column: span 1; }
  .gallery-item:nth-child(4) { grid-column: span 1; }
  .gallery-item:nth-child(5) { grid-column: span 1; }
  
  /* Second row - 5 items */
  .gallery-item:nth-child(6) { grid-column: span 1; }
  .gallery-item:nth-child(7) { grid-column: span 1; }
  .gallery-item:nth-child(8) { grid-column: span 1; }
  .gallery-item:nth-child(9) { grid-column: span 1; }
  .gallery-item:nth-child(10) { grid-column: span 1; }
  
  /* Third row - portraits spanning 2 rows, landscapes filling */
  .gallery-item:nth-child(11) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }
  .gallery-item:nth-child(12) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }
  .gallery-item:nth-child(13) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }
  .gallery-item:nth-child(14) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }
  .gallery-item:nth-child(15) { grid-column: span 2; aspect-ratio: 16/9; }
  .gallery-item:nth-child(16) { grid-column: span 1; grid-row: span 2; aspect-ratio: auto; }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.02);
  }

  .gallery-item {
    cursor: pointer;
  }

  .gallery-item:focus {
    outline: 2px solid #000;
    outline-offset: 2px;
  }

  /* Lightbox Styles */
  .lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .lightbox.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 80px;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: calc(100vh - 140px);
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    color: #fff;
    font-size: 40px;
    cursor: pointer;
    z-index: 1001;
    padding: 10px;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .lightbox-close:hover {
    transform: scale(1.1);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: #fff;
    font-size: 30px;
    cursor: pointer;
    padding: 20px 15px;
    z-index: 1001;
    transition: background 0.2s ease;
    border-radius: 4px;
  }

  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-prev {
    left: 20px;
  }

  .lightbox-next {
    right: 20px;
  }

  .lightbox-counter {
    color: #fff;
    font-size: 14px;
    margin-top: 15px;
    letter-spacing: 1px;
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
  }

  @media (max-width: 768px) {
    .lightbox-content {
      padding: 50px 50px;
    }

    .lightbox-content img {
      max-height: calc(100vh - 120px);
    }

    .lightbox-nav {
      padding: 15px 10px;
      font-size: 24px;
    }

    .lightbox-prev {
      left: 5px;
    }

    .lightbox-next {
      right: 5px;
    }

    .lightbox-close {
      top: 10px;
      right: 10px;
      font-size: 32px;
    }
  }

  .footer {
    text-align: center;
    padding: 30px 20px;
    font-size: 12px;
    color: #000;
  }

  .footer p {
    margin: 4px 0;
  }

  @media (max-width: 768px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
    }
    
    .gallery-item,
    .gallery-item:nth-child(n) {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
      aspect-ratio: 1 !important;
    }
  }

  @media (max-width: 480px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }

    .container {
      padding: 20px 15px;
    }
  }
</style>

<script>
  // Lightbox functionality
  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCounter = document.getElementById('lightbox-counter') as HTMLElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;
  const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement;
  const galleryItems = document.querySelectorAll('.gallery-item');
  
  let currentIndex = 0;
  const totalImages = galleryItems.length;

  // Get large image URL from data attribute
  function getImageSrc(index: number): string {
    const item = galleryItems[index] as HTMLElement;
    return item.dataset.largeSrc || '';
  }

  function getImageAlt(index: number): string {
    const img = galleryItems[index].querySelector('img');
    return img?.alt || `Photo ${index + 1}`;
  }

  function openLightbox(index: number): void {
    currentIndex = index;
    updateLightboxImage();
    lightbox.classList.add('active');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeLightbox(): void {
    lightbox.classList.remove('active');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Return focus to the gallery item
    (galleryItems[currentIndex] as HTMLElement).focus();
  }

  function updateLightboxImage(): void {
    lightboxImg.src = getImageSrc(currentIndex);
    lightboxImg.alt = getImageAlt(currentIndex);
    lightboxCounter.textContent = `${currentIndex + 1} / ${totalImages}`;
  }

  function showPrev(): void {
    currentIndex = (currentIndex - 1 + totalImages) % totalImages;
    updateLightboxImage();
  }

  function showNext(): void {
    currentIndex = (currentIndex + 1) % totalImages;
    updateLightboxImage();
  }

  // Event listeners for gallery items
  galleryItems.forEach((item, index) => {
    item.addEventListener('click', () => openLightbox(index));
    item.addEventListener('keydown', (e: Event) => {
      const keyEvent = e as KeyboardEvent;
      if (keyEvent.key === 'Enter' || keyEvent.key === ' ') {
        e.preventDefault();
        openLightbox(index);
      }
    });
  });

  // Event listeners for lightbox controls
  closeBtn.addEventListener('click', closeLightbox);
  prevBtn.addEventListener('click', showPrev);
  nextBtn.addEventListener('click', showNext);

  // Close on backdrop click
  lightbox.addEventListener('click', (e: Event) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (!lightbox.classList.contains('active')) return;
    
    switch (e.key) {
      case 'Escape':
        closeLightbox();
        break;
      case 'ArrowLeft':
        showPrev();
        break;
      case 'ArrowRight':
        showNext();
        break;
    }
  });

  // Touch swipe support for mobile
  let touchStartX = 0;
  let touchEndX = 0;

  lightbox.addEventListener('touchstart', (e: TouchEvent) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });

  lightbox.addEventListener('touchend', (e: TouchEvent) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  }, { passive: true });

  function handleSwipe(): void {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0) {
        showNext(); // Swipe left = next
      } else {
        showPrev(); // Swipe right = prev
      }
    }
  }
</script>
